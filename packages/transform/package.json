{
  "name": "@manuscripts/transform",
  "description": "JATS ↔ ProseMirror transformation pipeline for Manuscripts applications",
  "version": "4.3.27",
  "repository": "github:Atypon-OpenSource/manuscripts-transform",
  "license": "Apache-2.0",
  "main": "dist/cjs/index.js",
  "module": "dist/es/index.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "keywords": [
    "jats",
    "prosemirror",
    "transform",
    "manuscripts"
  ],
  "scripts": {
    "build": "npm-run-all --parallel build:cjs build:es",
    "build:cjs": "tsc --outDir dist/cjs --module commonjs",
    "build:es": "tsc --outDir dist/es --declarationDir dist/types --declaration",
    "prebuild": "rimraf dist && pnpm version-file",
    "version-file": "node -p \"'export const VERSION = ' + JSON.stringify(require('./package.json').version) + ';'\" > src/version.ts",
    "dev": "pnpm version-file && npm-run-all --parallel \"build:cjs --watch\" \"build:es --watch\"",
    "test": "TZ=UTC jest --runInBand",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .js,.ts",
    "lint:fix": "eslint src --fix --ext .js,.ts",
    "prettier": "prettier --write \"src/**/*.{ts,tsx}\" \"*.{js,json}\""
  },
  "dependencies": {
    "@manuscripts/schema": "workspace:*",
    "citeproc": "2.4.63",
    "prosemirror-model": "1.25.0",
    "prosemirror-utils": "1.2.2",
    "uuid": "9.0.1",
    "w3c-xmlserializer": "4.0.0"
  },
  "engines": {
    "node": ">=20.16.0"
  }
}
