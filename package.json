{
  "name": "manuscripts-transform-workspace",
  "private": true,
  "description": "Monorepo: @manuscripts/schema (ProseMirror schema) and @manuscripts/transform (JATS ↔ ProseMirror)",
  "repository": "github:Atypon-OpenSource/manuscripts-transform",
  "license": "Apache-2.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r dev",
    "lint": "eslint packages --ext .js,.ts",
    "lint:fix": "eslint packages --fix --ext .js,.ts",
    "prettier": "prettier --write \"packages/**/*.{ts,tsx}\" \"*.{js,json}\"",
    "test": "TZ=UTC jest --runInBand",
    "typecheck": "pnpm --filter @manuscripts/schema build:types && pnpm -r typecheck"
  },
  "devDependencies": {
    "@babel/core": "7.23.7",
    "@babel/preset-env": "7.23.8",
    "@babel/preset-typescript": "7.23.3",
    "@eslint/eslintrc": "3.3.1",
    "@eslint/js": "9.39.1",
    "@jats4r/dtds": "0.0.10",
    "@manuscripts/eslint-config": "0.5.1",
    "@types/csl": "npm:csl-json@0.1.0",
    "@types/jest": "30.0.0",
    "@types/lodash": "4.17.16",
    "@types/node": "20.17.46",
    "@types/semver": "7.7.0",
    "@types/uuid": "9.0.8",
    "@types/w3c-xmlserializer": "2.0.4",
    "@typescript-eslint/eslint-plugin": "8.46.4",
    "@typescript-eslint/parser": "8.46.4",
    "babel-jest": "30.0.5",
    "eslint": "9.39.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-diff": "2.0.3",
    "eslint-plugin-header": "3.1.1",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jest": "29.1.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-mdx": "3.6.2",
    "eslint-plugin-node": "11.1.0",
    "eslint-plugin-prettier": "5.5.4",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "husky": "8.0.3",
    "jest": "30.0.5",
    "jest-environment-jsdom": "30.0.5",
    "libxmljs2": "0.35.0",
    "npm-run-all": "4.1.5",
    "prettier": "3.6.2",
    "rimraf": "6.0.1",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=20.16.0"
  }
}
